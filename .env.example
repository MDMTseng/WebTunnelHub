# Required: copy to `.env` and fill every variable below (hub-common.sh has no defaults).
# Do not commit `.env` (see `.gitignore`). You may `export` these instead of using a file.

# --- SSH / EC2 ---
SSH_TARGET=YOURUSER@your-ec2-host.example.com
SSH_KEY=/path/to/your/private/key.pem
# Windows PowerShell example: SSH_KEY=C:/Users/you/.ssh/your-key.pem
SSH_PORT=22

# --- Paths on EC2 (Caddy) ---
HUB_DIR=/etc/caddy/hub-routes
MAIN_CFG=/etc/caddy/Caddyfile

# --- Public URL (for script messages only; must match Caddy site + TLS) ---
HUB_PUBLIC_URL=https://your-domain.example.com:1080

# Optional: hub-unregister — skip server-side tunnel teardown (fuser/lsof on EC2). Default is to kill the listener on EC2.
# HUB_KILL_TUNNEL_ON_EC2=0
