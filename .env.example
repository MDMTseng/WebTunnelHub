# Required: copy to `.env` and fill every variable below (hub-common.sh has no defaults).
# Do not commit `.env` (see `.gitignore`). You may `export` these instead of using a file.

# --- SSH / hub host ---
SSH_TARGET=YOURUSER@your-hub-host.example.com
SSH_KEY=/path/to/your/private/key.pem
# Windows (Git Bash / WSL): SSH_KEY=C:/Users/you/.ssh/your-key.pem
SSH_PORT=22

# --- Paths on hub host (Caddy) ---
HUB_DIR=/etc/caddy/hub-routes
MAIN_CFG=/etc/caddy/Caddyfile

# --- Public URL (script messages + parsing host/port for https://<AppName>.<host>:<port>/ ) ---
# Prefer exposing services only via registered Hub apps (lowercase names). The bare https://host:port/ root path is legacy.
# Example base: https://db.example.com:1080 → app URLs like https://myapp.db.example.com:1080/
HUB_PUBLIC_URL=https://your-domain.example.com:1080

# Optional: hub-unregister — skip server-side tunnel teardown (fuser/lsof on hub). Default is to kill the listener there.
# Variable name is legacy; it applies to SSH_TARGET, not a specific cloud vendor.
# HUB_KILL_TUNNEL_ON_EC2=0

# Optional: extra ssh arguments (space-separated), e.g. -o ProxyJump=bastion.example.com
# SSH_OPTS=-o ProxyJump=bastion

# Optional: directory for hub-tunnel.sh --background logs (default: logs)
# HUB_TUNNEL_LOG_DIR=logs

